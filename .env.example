# 安全配置
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 数据库
DATABASE_URL=sqlite+aiosqlite:///./translation_api.db

# 默认管理员账号（首次启动时创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
ADMIN_EMAIL=admin@example.com

# API 配置
# 公开 API 基础地址，留空时后台 API 文档会自动使用当前访问地址
# API_BASE_URL=https://api.example.com

# 模型配置
DEFAULT_MODEL=argos
DEVICE=cpu
ARGOS_WARMUP_PAIRS=en-zh,zh-en
M2M100_MODEL=facebook/m2m100_418M
M2M100_LARGE_MODEL=facebook/m2m100_1.2B
M2M100_BACKEND=auto
NLLB_MODEL=facebook/nllb-200-distilled-600M
NLLB_BACKEND=auto
QWEN3_MODEL=Qwen/Qwen3-1.7B
GEMMA3_MODEL=google/gemma-3-1b-it
QWEN2_5_MODEL=Qwen/Qwen2.5-0.5B-Instruct
TRANSLATION_MAX_NEW_TOKENS=128
TRANSLATION_BATCH_SIZE=8
LLM_MAX_INPUT_TOKENS=1024
LLM_TRANSLATION_MAX_NEW_TOKENS=512
# 0 表示自动：CUDA 默认批量 4，CPU 默认 1；显存不足时可设为 1
LLM_TRANSLATION_BATCH_SIZE=0
TORCH_CPU_THREADS=0
MODEL_WARMUP_ENABLED=true
TRANSFORMER_WARMUP_MODELS=marian
TRANSFORMER_WARMUP_PAIRS=zh-en,en-zh
MARIAN_BACKEND=auto
CTRANSLATE2_MODELS_DIR=./models/ctranslate2
MARIAN_CT2_COMPUTE_TYPE=int8
MARIAN_CT2_INTER_THREADS=1
MARIAN_CT2_INTRA_THREADS=0
MARIAN_CT2_MAX_QUEUED_BATCHES=0
M2M100_CT2_COMPUTE_TYPE=int8
M2M100_CT2_INTER_THREADS=1
M2M100_CT2_INTRA_THREADS=0
M2M100_CT2_MAX_QUEUED_BATCHES=0
NLLB_CT2_COMPUTE_TYPE=int8
NLLB_CT2_INTER_THREADS=1
NLLB_CT2_INTRA_THREADS=0
NLLB_CT2_MAX_QUEUED_BATCHES=0

# HuggingFace 镜像（可选，国内下载模型时可启用）
# HF_ENDPOINT=https://hf-mirror.com
